---
import { email, phoneNumber, socialLinks, googleMapsLink } from "@/const";

interface Props {
  type?: "home" | "page" | "project" | "contact" | "about" | "collection";
  pageTitle?: string;
  pageDescription?: string;
  breadcrumbs?: Array<{ name: string; url: string }>;
  collectionItems?: Array<{
    name: string;
    url: string;
    image: string;
  }>;
}

const {
  type = "page",
  pageTitle = "Ebanos Muebles",
  pageDescription = "",
  breadcrumbs = [],
  collectionItems,
} = Astro.props;

const siteUrl = "https://ebanosmuebles.com";
const currentUrl = new URL(Astro.url.pathname, siteUrl).href;

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": ["Organization", "LocalBusiness", "FurnitureStore"],
  "@id": `${siteUrl}/#organization`,
  name: "Ebanos Muebles",
  alternateName: [
    "Ebanos Muebles Perú",
    "Ebanos Muebles Chiclayo",
    "Mueblería Ebanos",
  ],
  description:
    "Fabricantes de muebles a medida con más de 30 años de experiencia en Chiclayo, Perú. Especialistas en muebles de madera de alta calidad para hogares y empresas.",
  url: siteUrl,
  logo: {
    "@type": "ImageObject",
    url: `${siteUrl}/favicon.webp`,
    width: 512,
    height: 512,
  },
  image: [
    `${siteUrl}/assets/image1.webp`,
    `${siteUrl}/assets/sobre-nosotros.webp`,
    `${siteUrl}/assets/experto.webp`,
  ],
  telephone: phoneNumber,
  email: email,
  address: {
    "@type": "PostalAddress",
    streetAddress: "Nicaragua 1140",
    addressLocality: "Chiclayo",
    addressRegion: "Lambayeque",
    postalCode: "14001",
    addressCountry: "PE",
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: -6.7713,
    longitude: -79.8408,
  },
  areaServed: [
    {
      "@type": "City",
      name: "Chiclayo",
    },
    {
      "@type": "City",
      name: "José Leonardo Ortiz",
    },
    {
      "@type": "City",
      name: "La Victoria",
    },
    {
      "@type": "State",
      name: "Lambayeque",
    },
    {
      "@type": "Country",
      name: "Perú",
    },
  ],
  openingHoursSpecification: [
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: [
        "Monday",
        "Tuesday",
        "Wednesday",
        "Thursday",
        "Friday",
        "Saturday",
      ],
      opens: "08:00",
      closes: "20:00",
    },
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: "Sunday",
      opens: "08:00",
      closes: "15:00",
    },
  ],
  priceRange: "$$",
  currenciesAccepted: "PEN",
  paymentAccepted: "Cash, Bank Transfer, Yape, Plin",
  foundingDate: "1990",
  founder: {
    "@id": `${siteUrl}/#founder`,
  },
  numberOfEmployees: {
    "@type": "QuantitativeValue",
    minValue: 5,
    maxValue: 15,
  },
  knowsAbout: [
    "Muebles a medida",
    "Carpintería fina",
    "Muebles de madera",
    "Muebles de melamina",
    "Closets",
    "Cocinas integrales",
    "Muebles de dormitorio",
    "Comedores",
    "Muebles de sala",
    "Puertas de madera",
    "Portones",
  ],
  hasOfferCatalog: {
    "@type": "OfferCatalog",
    name: "Catálogo de Muebles a Medida",
    itemListElement: [
      {
        "@type": "OfferCatalog",
        name: "Muebles de Dormitorio",
        itemListElement: [
          {
            "@type": "Offer",
            itemOffered: { "@type": "Service", name: "Camas de madera" },
          },
          {
            "@type": "Offer",
            itemOffered: { "@type": "Service", name: "Closets a medida" },
          },
          {
            "@type": "Offer",
            itemOffered: { "@type": "Service", name: "Veladores" },
          },
          {
            "@type": "Offer",
            itemOffered: { "@type": "Service", name: "Roperos" },
          },
        ],
      },
      {
        "@type": "OfferCatalog",
        name: "Muebles de Comedor",
        itemListElement: [
          {
            "@type": "Offer",
            itemOffered: { "@type": "Service", name: "Mesas de comedor" },
          },
          {
            "@type": "Offer",
            itemOffered: { "@type": "Service", name: "Sillas de comedor" },
          },
          {
            "@type": "Offer",
            itemOffered: { "@type": "Service", name: "Aparadores" },
          },
        ],
      },
      {
        "@type": "OfferCatalog",
        name: "Muebles de Cocina",
        itemListElement: [
          {
            "@type": "Offer",
            itemOffered: { "@type": "Service", name: "Cocinas integrales" },
          },
          {
            "@type": "Offer",
            itemOffered: { "@type": "Service", name: "Reposteros" },
          },
        ],
      },
      {
        "@type": "OfferCatalog",
        name: "Carpintería Exterior",
        itemListElement: [
          {
            "@type": "Offer",
            itemOffered: { "@type": "Service", name: "Puertas de madera" },
          },
          {
            "@type": "Offer",
            itemOffered: { "@type": "Service", name: "Portones" },
          },
          {
            "@type": "Offer",
            itemOffered: { "@type": "Service", name: "Portones levadizos" },
          },
        ],
      },
    ],
  },
  contactPoint: [
    {
      "@type": "ContactPoint",
      telephone: phoneNumber,
      contactType: "customer service",
      availableLanguage: ["Spanish"],
      areaServed: "PE",
      hoursAvailable: {
        "@type": "OpeningHoursSpecification",
        dayOfWeek: [
          "Monday",
          "Tuesday",
          "Wednesday",
          "Thursday",
          "Friday",
          "Saturday",
          "Sunday",
        ],
        opens: "08:00",
        closes: "20:00",
      },
    },
    {
      "@type": "ContactPoint",
      telephone: phoneNumber,
      contactType: "sales",
      availableLanguage: ["Spanish"],
      areaServed: "PE",
      contactOption: "TollFree",
    },
  ],
  hasMap: googleMapsLink,
  makesOffer: [
    {
      "@type": "Offer",
      itemOffered: {
        "@type": "Service",
        name: "Fabricación de muebles a medida",
        description:
          "Diseño y fabricación de muebles personalizados en madera de cedro y melamina para hogares y empresas.",
        areaServed: {
          "@type": "City",
          name: "Chiclayo",
          containedInPlace: {
            "@type": "State",
            name: "Lambayeque",
            containedInPlace: {
              "@type": "Country",
              name: "Perú",
            },
          },
        },
        serviceType: "Carpintería y mueblería a medida",
        provider: {
          "@id": `${siteUrl}/#organization`,
        },
      },
    },
    {
      "@type": "Offer",
      itemOffered: {
        "@type": "Service",
        name: "Instalación de puertas y portones",
        description:
          "Fabricación e instalación de puertas de madera, portones y portones levadizos.",
        areaServed: {
          "@type": "State",
          name: "Lambayeque",
          containedInPlace: {
            "@type": "Country",
            name: "Perú",
          },
        },
        serviceType: "Carpintería exterior",
        provider: {
          "@id": `${siteUrl}/#organization`,
        },
      },
    },
  ],
  sameAs: [
    socialLinks.facebook,
    socialLinks.instagram,
    socialLinks.tiktok,
  ],
};

const founderSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": `${siteUrl}/#founder`,
  name: "Huildor Fernandez Cayao",
  jobTitle: "Fundador y Maestro Carpintero",
  description:
    "Maestro carpintero con más de 30 años de experiencia en fabricación de muebles a medida. Fundador de Ebanos Muebles en 1990 en Chiclayo, Perú.",
  image: `${siteUrl}/assets/experto.webp`,
  url: `${siteUrl}/sobre-nosotros`,
  worksFor: {
    "@id": `${siteUrl}/#organization`,
  },
  knowsAbout: [
    "Carpintería fina",
    "Fabricación de muebles a medida",
    "Muebles de madera de cedro",
    "Muebles de melamina",
    "Diseño de mobiliario",
    "Puertas y portones de madera",
    "Cocinas integrales",
    "Closets y roperos",
  ],
  nationality: {
    "@type": "Country",
    name: "Perú",
  },
  workLocation: {
    "@type": "Place",
    name: "Taller Ebanos Muebles",
    address: {
      "@type": "PostalAddress",
      streetAddress: "Nicaragua 1140",
      addressLocality: "Chiclayo",
      addressRegion: "Lambayeque",
      addressCountry: "PE",
    },
  },
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": `${siteUrl}/#website`,
  url: siteUrl,
  name: "Ebanos Muebles",
  description:
    "Fábrica de muebles a medida en Chiclayo, Perú. Más de 30 años de experiencia.",
  publisher: {
    "@id": `${siteUrl}/#organization`,
  },
  inLanguage: "es-PE",
};

const webPageSchema = {
  "@context": "https://schema.org",
  "@type":
    type === "home"
      ? "WebPage"
      : type === "contact"
        ? "ContactPage"
        : type === "about"
          ? "AboutPage"
          : type === "collection"
            ? "CollectionPage"
            : "WebPage",
  "@id": `${currentUrl}#webpage`,
  url: currentUrl,
  name: pageTitle,
  description: pageDescription,
  isPartOf: {
    "@id": `${siteUrl}/#website`,
  },
  about: {
    "@id": `${siteUrl}/#organization`,
  },
  inLanguage: "es-PE",
};

const breadcrumbSchema =
  breadcrumbs.length > 0
    ? {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        itemListElement: breadcrumbs.map((item, index) => ({
          "@type": "ListItem",
          position: index + 1,
          name: item.name,
          item: item.url.startsWith("http")
            ? item.url
            : `${siteUrl}${item.url}`,
        })),
      }
    : null;

const schemas: any[] = [organizationSchema, websiteSchema, webPageSchema];

if (type === "home" || type === "about") {
  schemas.push(founderSchema);
}

if (breadcrumbSchema) {
  schemas.push(breadcrumbSchema);
}

const itemListSchema =
  collectionItems && collectionItems.length > 0
    ? {
        "@context": "https://schema.org",
        "@type": "ItemList",
        itemListElement: collectionItems.map((item, index) => ({
          "@type": "ListItem",
          position: index + 1,
          name: item.name,
          url: item.url.startsWith("http") ? item.url : `${siteUrl}${item.url}`,
          image: item.image.startsWith("http")
            ? item.image
            : `${siteUrl}${item.image}`,
        })),
      }
    : null;

if (itemListSchema) {
  schemas.push(itemListSchema);
}
---

{
  schemas.map((schema) => (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  ))
}
