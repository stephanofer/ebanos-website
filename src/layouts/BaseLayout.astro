---
import MainHead from "@/components/MainHead.astro";
import { ClientRouter } from "astro:transitions";
import Footer from "@/components/Footer.astro";
import Navbar from "@/components/Navbar.astro";
import Announce from "@/components/Announce.astro";
import Experiencias from "@/sections/Experiencias.astro";
import "@/styles/global.css";

interface Props {
  title?: string;
  description?: string;
  pageType?: "home" | "page" | "project" | "contact" | "about" | "collection";
  breadcrumbs?: Array<{ name: string; url: string }>;
  collectionItems?: Array<{ name: string; url: string; image: string }>;
}

const {
  title = "Ebanos Muebles",
  description = "Fábrica de muebles a medida en Chiclayo, Perú. +30 años creando muebles de calidad.",
  pageType = "page",
  breadcrumbs = [],
  collectionItems,
} = Astro.props;
const googleTagManagerId = "GTM-KF6L4554";

---

<!doctype html>
<html lang="es">
  <head>
    <script is:inline define:vars={{ googleTagManagerId }}>
      if (!window.__ebanosGtmInitialized) {
        window.__ebanosGtmInitialized = true;
        window.dataLayer = window.dataLayer || [];

        (function (w, d, s, l, i) {
          w[l] = w[l] || [];
          w[l].push({ "gtm.start": new Date().getTime(), event: "gtm.js" });
          var f = d.getElementsByTagName(s)[0],
            j = d.createElement(s),
            dl = l != "dataLayer" ? "&l=" + l : "";
          j.async = true;
          j.src = "https://www.googletagmanager.com/gtm.js?id=" + i + dl;
          f.parentNode.insertBefore(j, f);
        })(window, document, "script", "dataLayer", googleTagManagerId);
      }
    </script>
    <style is:inline>
      @font-face {
        font-family: "Inter";
        font-style: normal;
        font-weight: 100 900;
        font-display: swap;
        src: url("/fonts/Inter.woff2") format("woff2");
      }

      @font-face {
        font-family: "Clash";
        font-style: normal;
        font-weight: 200 700;
        font-display: swap;
        src: url("/fonts/Clash.woff2") format("woff2");
      }

      *,
      *::after,
      *::before {
        box-sizing: border-box;
        margin: 0;
      }

      html,
      body {
        width: 100%;
        height: 100%;
        margin: 0;
        font-family:
          "Inter",
          ui-sans-serif,
          system-ui,
          -apple-system,
          BlinkMacSystemFont,
          "Segoe UI",
          Roboto,
          sans-serif;
      }
    </style>
    <MainHead
      title={title}
      description={description}
      pageType={pageType}
      breadcrumbs={breadcrumbs}
      collectionItems={collectionItems}
    />
    <ClientRouter />
  </head>
  <body>
    <noscript>
      <iframe
        src={`https://www.googletagmanager.com/ns.html?id=${googleTagManagerId}`}
        height="0"
        width="0"
        style="display:none;visibility:hidden"
      ></iframe>
    </noscript>
    <Announce />
    <Navbar />
    <main>
      <slot />
      <Experiencias />
    </main>
    <Footer />
  </body>
</html>
